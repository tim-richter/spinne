{
  "name": "spinne",
  "version": "0.0.2",
  "description": "Spins a web of components and analyzes prop usage, adoption and more",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/tim-richter/spinne"
  },
  "bugs": "https://github.com/tim-richter/spinne/issues",
  "author": "Tim Richter",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "spinne": "./bin/spinne.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --minify --dts",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest watch --coverage",
    "test:debug": "ndb vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "knip": "knip"
  },
  "dependencies": {
    "@typescript-eslint/typescript-estree": "7.17.0",
    "commander": "12.1.0",
    "estree-walker": "3.0.3",
    "fdir": "6.2.0",
    "fs-extra": "11.2.0",
    "pino": "9.3.1",
    "pino-pretty": "11.2.1"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/node": "20.14.11",
    "@vitest/coverage-v8": "1.6.0",
    "biome": "0.3.3",
    "esbuild": "0.20.2",
    "knip": "5.27.0",
    "msw": "2.3.3",
    "ndb": "1.1.5",
    "tsup": "8.2.3",
    "typescript": "5.5.4",
    "vite": "5.3.4",
    "vitest": "1.6.0",
    "vitest-mock-extended": "1.3.2"
  }
}
