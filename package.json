{
  "name": "spinne",
  "version": "0.0.2",
  "description": "Spins a web of components and analyzes prop usage, adoption and more",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/tim-richter/spinne"
  },
  "bugs": "https://github.com/tim-richter/spinne/issues",
  "author": "Tim Richter",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "spinne": "./bin/spinne.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest watch --coverage",
    "test:debug": "ndb vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:tsc": "tsc --noEmit --diagnostics",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@typescript-eslint/typescript-estree": "7.17.0",
    "estree-walker": "3.0.3",
    "fdir": "6.2.0",
    "fs-extra": "11.2.0",
    "pino": "9.3.2",
    "pino-pretty": "11.2.2",
    "typescript": "5.5.4",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "@commitlint/cli": "19.4.0",
    "@commitlint/config-conventional": "19.2.2",
    "@types/fs-extra": "11.0.4",
    "@types/node": "22.1.0",
    "@types/yargs": "17.0.33",
    "@vitest/coverage-v8": "1.6.0",
    "esbuild": "0.20.2",
    "execa": "9.3.0",
    "husky": "9.1.4",
    "knip": "5.27.2",
    "msw": "2.3.5",
    "ndb": "1.1.5",
    "semantic-release": "24.0.0",
    "tsup": "8.2.4",
    "vite": "5.4.0",
    "vitest": "1.6.0",
    "vitest-mock-extended": "1.3.2"
  }
}
